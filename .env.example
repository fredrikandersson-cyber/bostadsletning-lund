# Frontend environment variables
VITE_API_URL=http://localhost:3000

# Backend environment variables (for Vercel deployment)
DATABASE_URL=postgresql://user:password@localhost:5432/bostadsletning
JWT_SECRET=your-secret-key-here
NODE_ENV=development

# Email configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@example.com

# Hemnet API
HEMNET_API_KEY=your-hemnet-api-key
HEMNET_API_URL=https://api.hemnet.se

# Blocket API
BLOCKET_API_KEY=your-blocket-api-key

# App configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
