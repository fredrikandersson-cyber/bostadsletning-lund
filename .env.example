# Frontend environment variables
VITE_API_URL=http://localhost:3000

# Backend environment variables (for Vercel deployment)
DATABASE_URL=postgresql://user:password@localhost:5432/bostadsletning
JWT_SECRET=your-secret-key-here
NODE_ENV=development

# Email – välj ett alternativ:

# Alternativ 1: Gmail (enklast för personligt bruk)
# Skapa ett "App-lösenord" på https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din@gmail.com
SMTP_PASS=ditt-app-losenord

# Alternativ 2: SendGrid (bättre leveransbarhet)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Avsändaradress (används oavsett alternativ)
APP_URL=https://din-app.vercel.app

# Hemnet API
HEMNET_API_KEY=your-hemnet-api-key
HEMNET_API_URL=https://api.hemnet.se

# Blocket API
BLOCKET_API_KEY=your-blocket-api-key

# App configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
